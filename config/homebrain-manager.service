[Unit]
Description=HomeBrain Manager
After=network.target
StartLimitIntervalSec=600
StartLimitBurst=5

[Service]
User=root
WorkingDirectory=/opt/homebrain/src
# Include /sbin and /usr/sbin so the manager's subprocess calls find
# admin tools that live there (blkid, mount, mkfs.*, parted, ip, etc.).
# Debian/Ubuntu root historically gets this PATH; systemd starts services
# with a stripped one unless we set it explicitly.
Environment="PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/sbin:/usr/bin:/bin"
# gevent worker class is required for the /openclaw WebSocket reverse-proxy
# (flask-sock + simple-websocket). gunicorn auto-applies gevent monkey-patch
# at startup so existing subprocess/threading code keeps working — long
# blocking calls just yield to other greenlets instead of stalling the worker.
ExecStart=/opt/homebrain/venv/bin/gunicorn --worker-class gevent --workers 3 --bind 0.0.0.0:80 --timeout 30 app:app
Restart=always
RestartSec=10
TimeoutStartSec=60
TimeoutStopSec=30
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
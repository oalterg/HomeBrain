            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 131072,
            "maxTokens": 8192
          }
        ]
      },
      "openai": {
        "apiKey": "dummy-local-whisper",
        "baseUrl": "http://127.0.0.1:8002/v1",
        "models": []
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {

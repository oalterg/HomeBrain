# HomeBrain LAN HTTPS edge — used in local-mode deployments to satisfy
# Bitwarden mobile/desktop clients (which refuse plain HTTP).
#
# In remote-mode deployments Pangolin terminates TLS at the public edge and
# this proxy is unused (still running so a mode flip doesn't require
# restarting the stack).
#
# Caddy mints an internal CA on first start and issues leaf certs for the
# hostnames below. The CA root is exposed at /api/vault/local-ca on the
# dashboard so it can be downloaded and trusted once per client device.
# Persistent state lives in the caddy_data named volume.
#
# Hostnames are hardcoded to the canonical mDNS names. If you reach the box
# by raw LAN IP, install the CA first and use https://homebrain.local:8443
# from your client — mDNS works on iOS/macOS/Windows 10+/Android out of the
# box. Adding more hostnames here is safe; Caddy mints a SAN per address.

{
	auto_https disable_redirects
	admin off
	# Serve the homebrain.local cert when the client connects without SNI
	# (curl, some legacy mobile clients, anything hitting the box by raw IP
	# without SNI). Modern browsers send SNI even for IP literals so they
	# match the explicit IP route below; this is the safety net.
	default_sni homebrain.local
	log {
		output stdout
		format console
		level WARN
	}
}

# Catch-all on :8443. `tls internal` mints a per-SNI cert for each address
# below. {$VAULT_LAN_IP} is substituted from the env at startup so the box's
# LAN IP gets a valid SAN — without it, browsers reaching the box by raw IP
# fail TLS handshake. Falls back to a placeholder when LAN_IP is unset (the
# placeholder also resolves to localhost so it never matches real traffic).
homebrain.local:8443, vault.homebrain.local:8443, 127.0.0.1:8443, {$VAULT_LAN_IP:127.0.0.2}:8443 {
	tls internal

	@health path /healthz
	respond @health 200

	reverse_proxy vaultwarden:80 {
		header_up X-Forwarded-Proto https
	}
}
